; Copy this file to platformio_secrets.ini (which is .gitignored) and fill in
; the four secrets. These override the placeholder build_flags in
; platformio.ini.

[env:seeed_xiao_esp32s3]
build_flags =
    -UWIFI_SSID
    -UWIFI_PASS
    -UDEVICE_TOKEN
    -UWIFI_SSID
    -UWIFI_PASS
    -UDEVICE_TOKEN
    -DWIFI_SSID=\"my-wifi\"
    -DWIFI_PASS=\"my-wifi-password\"
    -DDEVICE_TOKEN=\"trmnl_XXXXXXXXXXXXXXXXXXXXXX\"
    ; SERVER_URL is already correct in platformio.ini; override here only if
    ; you're pointing the device at a different host.
    ; -USERVER_URL
    ; -DSERVER_URL=\"http://192.168.1.50:3000\"
