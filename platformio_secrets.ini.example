; Copy this file to platformio_secrets.ini (which is .gitignored) and fill in
; the three secrets. The ${common.build_flags} reference is required — the
; secrets file's build_flags REPLACES the env's build_flags, so we have to
; pull the non-secret defines back in.

[env:seeed_xiao_esp32s3]
build_flags =
    ${common.build_flags}
    -DWIFI_SSID=\"my-wifi\"
    -DWIFI_PASS=\"my-wifi-password\"
    -DDEVICE_TOKEN=\"trmnl_XXXXXXXXXXXXXXXXXXXXXX\"
